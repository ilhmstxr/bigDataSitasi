# ===== Server =====
PORT=3100
HOST=0.0.0.0

# ===== MySQL (gunakan database yang sama dengan folder Server/ agar
#  endpoint /api/sensor/latest membaca data ESP32 yang sudah masuk) =====
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=big_data_sitasi
MYSQL_CONNECTION_LIMIT=10

# ===== BMKG Proxy =====
BMKG_AUTOGEMPA_URL=https://data.bmkg.go.id/DataMKG/TEWS/autogempa.json
BMKG_TIMEOUT_MS=8000

# ===== Default device id untuk /api/sensor/latest =====
# Dipakai jika request tidak menyertakan ?device_id=
DEFAULT_DEVICE_ID=ESP32_Mesin_01

# ===== Cut-off umur data sensor (detik) =====
# Endpoint /api/sensor/latest akan mengembalikan 410 Gone jika data terbaru
# lebih tua dari STALE_AFTER_SEC. 0 = nonaktif.
STALE_AFTER_SEC=300
