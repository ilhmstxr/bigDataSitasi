# ===== Server =====
PORT=3000
HOST=0.0.0.0

# ===== MySQL =====
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=big_data_sitasi
MYSQL_CONNECTION_LIMIT=10

# ===== Anomaly Thresholds =====
THRESHOLD_TEMP=60.0
# Ambang SI Kayser sisi server (default 5.0 = "Gempa Terdeteksi").
THRESHOLD_SI_KAYSER=5.0

# ===== n8n Webhook =====
# Kosongkan untuk menonaktifkan trigger anomaly
N8N_WEBHOOK_URL=
N8N_WEBHOOK_TIMEOUT_MS=5000
